# VeritasGraph MCP Server Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration
# =============================================================================

# API Key for LLM provider (OpenAI, Azure, or local like Ollama)
GRAPHRAG_API_KEY=ollama

# Base URL for LLM API
# For Ollama: http://127.0.0.1:11434/v1
# For OpenAI: https://api.openai.com/v1
# For Azure: https://your-resource.openai.azure.com
GRAPHRAG_LLM_API_BASE=http://127.0.0.1:11434/v1

# Model name for chat/completion
# For Ollama: llama3.1:latest, mistral:latest, etc.
# For OpenAI: gpt-4-turbo-preview, gpt-4o, etc.
GRAPHRAG_LLM_MODEL=llama3.1:latest

# =============================================================================
# Embedding Configuration
# =============================================================================

# Base URL for embedding API (can be different from LLM)
GRAPHRAG_EMBEDDING_API_BASE=http://127.0.0.1:11434/v1

# Embedding model name
# For Ollama: nomic-embed-text, mxbai-embed-large, etc.
# For OpenAI: text-embedding-3-small, text-embedding-ada-002, etc.
EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# Optional: VeritasGraph MCP Server Configuration
# =============================================================================

# Override default output directory (where GraphRAG artifacts are stored)
# VERITAS_OUTPUT_DIR=/path/to/output/artifacts

# Override default input directory (where documents are stored)
# VERITAS_INPUT_DIR=/path/to/input

# Default community level for queries (1-5, higher = more detailed)
# VERITAS_COMMUNITY_LEVEL=2

# Default LLM temperature for responses (0.0-1.0)
# VERITAS_TEMPERATURE=0.5

# Default response format
# Options: Single Paragraph, Multiple Paragraphs, List of 3-7 Points, Single Page, Multi-Page Report
# VERITAS_RESPONSE_TYPE=Multiple Paragraphs

# =============================================================================
# Optional: Azure OpenAI Configuration
# =============================================================================

# Uncomment for Azure OpenAI
# GRAPHRAG_API_TYPE=azure
# GRAPHRAG_API_VERSION=2024-02-15-preview
# GRAPHRAG_DEPLOYMENT_NAME=your-deployment-name
