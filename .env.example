# ==============================================================================
# VeritasGraph - Root Environment Configuration (Template)
# ==============================================================================
# Copy this file to `.env` and fill in your values.
# NEVER commit a populated .env file. The .env file is gitignored.

# --- GitHub (optional) -------------------------------------------------------
# Used by scripts/start-with-pages-sync.sh to update GitHub Pages.
# Required scopes: repo
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_replace_me_with_your_token

# --- LLM Providers (choose one or more) --------------------------------------
# OpenAI / OpenAI-compatible (Azure, Together, Groq, Nebius, etc.)
OPENAI_API_KEY=sk-replace_me
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (optional, for Claude models)
ANTHROPIC_API_KEY=sk-ant-replace_me

# --- Local Models via Ollama (optional, for --mode=local) --------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Storage / Index ---------------------------------------------------------
GRAPHRAG_INPUT_DIR=./graphrag-ollama-config/input
GRAPHRAG_OUTPUT_DIR=./graphrag-ollama-config/output
LANCEDB_URI=./graphrag-ollama-config/output/lancedb
